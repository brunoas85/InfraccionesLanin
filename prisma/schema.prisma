generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  MESA_DE_ENTRADAS
  RESPONSABLE_AREA
  ADMIN
}

enum Reparticion {
  DGA_APNAC
  DGAJ_APNAC
  DC_APNAC
  OTRA
}

enum Origen {
  GDE
  TAD
}

enum EstadoCaso {
  CARGADO
  EN_EVALUACION
  CON_DESCARGO
  RESUELTO
  CON_ORDEN_DE_PAGO
  PAGADO
}

enum ResultadoDisposicion {
  SANCIONADO
  ARCHIVADO
  SOBRESEIDO
}

enum Ugd {
  SUR
  CENTRO
  NORTE
}

enum TipoConsecuencia {
  DECOMISO
  APERCIBIMIENTO
  MULTA
}

enum CategoriaAdjunto {
  GENERAL
  DESCARGO
  RECURSO
  ACTA
  INFORME_ACTA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nombre       String
  rol          Rol
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  casosCreados     Caso[]            @relation("CasoCreadoPor")
  historialEventos HistorialEvento[]

  @@map("users")
}

model TipoInfraccion {
  id        String   @id @default(cuid())
  nombre    String
  montoMin  Decimal  @db.Decimal(12, 2)
  montoMax  Decimal  @db.Decimal(12, 2)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  casos Caso[]

  @@map("tipos_infraccion")
}

model Caso {
  id     String @id @default(cuid())
  numeroEE       String      @unique
  reparticion    Reparticion
  reparticionOtra String?
  origen         Origen

  infractorNombre String
  infractorDni    String?

  tipoInfraccionId String
  tipoInfraccion   TipoInfraccion @relation(fields: [tipoInfraccionId], references: [id])
  tipoInfraccionOtra String?

  fechaInfraccion     DateTime
  fechaRecepcionEE    DateTime
  sector              String
  ugd                 Ugd
  guardaparqueInterviniente String
  jefeGuardaparques   String
  descripcion         String?

  huboDescargo Boolean    @default(false)
  estado       EstadoCaso @default(CARGADO)

  createdById String
  createdBy   User   @relation("CasoCreadoPor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adjuntos         Adjunto[]
  descargo         Descargo?
  disposicion      Disposicion?
  ordenPago        OrdenPago?
  historialEventos HistorialEvento[]

  @@map("casos")
}

model Adjunto {
  id         String   @id @default(cuid())
  casoId     String
  caso       Caso     @relation(fields: [casoId], references: [id])
  nombreArchivo String
  rutaArchivo   String
  tipo          String
  categoria     CategoriaAdjunto @default(GENERAL)
  createdAt  DateTime @default(now())

  @@map("adjuntos")
}

model Descargo {
  id                String   @id @default(cuid())
  casoId            String   @unique
  caso              Caso     @relation(fields: [casoId], references: [id])
  fechaPresentacion DateTime
  createdAt         DateTime @default(now())

  @@map("descargos")
}

model Disposicion {
  id        String                @id @default(cuid())
  casoId    String                @unique
  caso      Caso                  @relation(fields: [casoId], references: [id])
  numero    String
  resultado ResultadoDisposicion
  monto     Decimal?              @db.Decimal(12, 2)
  consecuencias TipoConsecuencia[] @default([])
  fecha     DateTime              @default(now())

  @@map("disposiciones")
}

model OrdenPago {
  id                 String    @id @default(cuid())
  casoId             String    @unique
  caso               Caso      @relation(fields: [casoId], references: [id])
  pdfUrl             String
  codigoReferencia   String    @unique
  pagado             Boolean   @default(false)
  comprobanteUrl     String?
  fechaConciliacion  DateTime?
  conciliadoPor      String?
  createdAt          DateTime  @default(now())

  @@map("ordenes_pago")
}

model HistorialEvento {
  id        String   @id @default(cuid())
  casoId    String
  caso      Caso     @relation(fields: [casoId], references: [id])
  tipo      String
  detalle   String?
  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id])
  createdAt DateTime @default(now())

  @@map("historial_eventos")
}
